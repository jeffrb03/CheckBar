# ============================================================
# CheckBar - Ejemplo de Variables de Entorno
# ============================================================
# Copia este archivo como ".env" y rellena los valores reales.
# El archivo ".env" está en .gitignore y NUNCA debe subirse.
# ============================================================

# --- Google Gemini API Key ---
# Obtén tu key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Base de Datos (opcional) ---
DATABASE_URL=sqlite:///./checkbar.db
